<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body class="bg-info text-black">
    <%- include('partials/header')%>
        <form action="/newAuthor" method="POST">
            <label for="firstNameInput">First Name: </label>
            <input id="firstNameInput" class="form-group" placeholder="First Name" name="firstName">
            <br>
            <label for="lastNameInput">Last Name: </label>
            <input id="lastNameInput" class="form-group" placeholder="Last Name" name="lastName">
            <br>
            <label for="dobInput">Date of Birth: </label>
            <input type="date" name="dob">
            <br>
            <label for="dodInput">Date of Death: </label>
            <input type="date" name="dod">
            <br>
            <label for="sexInput">Sex: </label>
            <input type="radio" id="male" name="sex" value="M">
            <label for="male">Male</label>

            <input type="radio" id="female" name="sex" value="F">
            <label for="female">Female</label>
            <br>
            <label for="professionInput">Profession: </label>
            <input id="professionInput" class="form-group" placeholder="Profession" name="profession">
            <br>
            <label for="countryInput">Country: </label>
            <input id="countryInput" class="form-group" placeholder="Country" name="country">
            <br>
            <label for="portraitInput">Portrait URL: </label>
            <textarea id="portraitInput" class="form-group" placeholder="Add your URL here" name="portrait"></textarea>
            <br>
            <label for="biographyInput">Biography: </label>
            <textarea id="biographyInput" class="form-group" placeholder="Add the bio here" name="biography"></textarea>
            <br>
            <button class="btn btn-primary">Submit</button>
        </form>
        <%- include('partials/footer')%>
</body>

</html>