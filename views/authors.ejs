<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>All Authors</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('partials/navbar.ejs') %>
    <div class="page-wrap">
        <div class="card-clean">
            <h1 class="page-title h3">All Authors</h1>

            <% if (authors.length === 0) { %>
                <p class="mb-0">No authors found.</p>
            <% } %>

            <% for (let i of authors) { %>
                <div class="list-item-row">
                    <span><%= i.firstName %> <%= i.lastName %></span>
                    <div class="actions-inline">
                        <a href="/updateAuthor?authorId=<%= i.authorId %>" class="btn btn-sm btn-outline-primary">Update</a>
                        <a href="/deleteAuthor?authorId=<%= i.authorId %>" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('partials/footer')%>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>