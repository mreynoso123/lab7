<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quotes</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>
    <h1> All Quotes </h1>
    <% for(let i of quotes) { %>
        <a href="/updateQuote?quoteId=<%= i.quoteId%>">Update</a>
        <a href="/deleteQuote?quoteId=<%= i.quoteId %>">Delete</a>
        <%= i.quote%><br>
    <% } %>
    <%- include('partials/footer')%>
</body>
</html>