<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body class="bg-info text-black">
    <%- include('partials/navbar.ejs') %>
    <%- include('partials/header')%>

        <h1> Updating Quote</h1>
        
        <form action="/updateQuote" method="POST" >

            <input type="hidden" class="form-group" name="quoteId" value="<%= quoteInfo[0].quoteId%>">
            

            <textarea name="quote"><%= quoteInfo[0].quote %></textarea>
            
            <select name="authorId">
                <% for (author of authorsList) {%>

                    <% if (author.authorId == quoteInfo[0].authorId) { %>
                        <option value="<%= author.authorId%>" selected><%= author.firstName %> <%= author.lastName %></option>
                    <% } else {%>
                        <option value="<%= author.authorId %>"><%= author.firstName %> <%= author.lastName %></option>
                    <% } %>                    
                <% } %>

                <!-- <option value="1">Albert Einstein</option>
                <option value="2">Agatha Christie</option> -->
            </select><br><br>

            <select name="category">
                <% for (category of categoriesList) {%>
                    <% if (author.authorId == quoteInfo[0].authorId) { %>
                        <option value="<%= quoteInfo[0].category %>" selected><%= quoteInfo[0].category %></option>
                    <% } else {%>
                        <option value="<%=  %>"><%=  %></option>
                    <% } %>
                <% } %>
            </select>

            <button class="btn btn-primary">Update Quote!</button>
        </form>
        <%- include('partials/footer')%>
</body>

</html>